NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# Cron job /api/cron/checkin-reminder — Vercel envía Authorization: Bearer ${CRON_SECRET}
CRON_SECRET=generate-with-openssl-rand-hex-32

# Telegram bot que recibe los avisos de check-in
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-personal-telegram-chat-id

# Notion — calendario "Reservas Airbnb". Token de la integración interna
# (notion.so/profile/integrations) y el id de la base de datos compartida con ella.
NOTION_TOKEN=your-notion-integration-token
NOTION_DATABASE_ID=your-notion-database-id
